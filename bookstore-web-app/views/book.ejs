<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détail du livre</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <h1>Détail du livre</h1>
    <p><strong>Titre :</strong> <%= book.title %></p>
    <p><strong>Auteur :</strong> <%= book.author %></p>

    <h2>Modifier</h2>
    <form action="/inventory/<%= book.id %>/edit" method="POST">
        <label for="title">Titre</label>
        <input type="text" id="title" name="title" value="<%= book.title %>">

        <label for="author">Auteur</label>
        <input type="text" id="author" name="author" value="<%= book.author %>">

        <button type="submit">Mettre à jour</button>
    </form>

    <h2>Supprimer</h2>
    <form action="/inventory/<%= book.id %>/delete" method="POST">
        <button type="submit">Supprimer ce livre</button>
    </form>

    <p><a href="/inventory">← Retour à la liste</a></p>
</body>
</html>